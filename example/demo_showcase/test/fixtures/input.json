{
  "type": "page",
  "metadata": {
    "title": "Input",
    "description": "Input widget showcase"
  },
  "state": {
    "initial": {
      "counter": 0,
      "sliderValue": 50,
      "toggleValue": false,
      "agreeTerms": false,
      "selectedOption": "option1",
      "radioChoice": "a",
      "rangeValue": {
        "start": 20,
        "end": 80
      },
      "pickedDate": "",
      "pickedTime": "",
      "rangeStart": "",
      "rangeEnd": "",
      "pickedColor": "#2196F3",
      "stepperIndex": 0,
      "numberStepperValue": 5,
      "ratingValue": 3,
      "formName": "",
      "formEmail": "",
      "formResult": ""
    }
  },
  "content": {
    "type": "singleChildScrollView",
    "padding": {
      "all": 16
    },
    "child": {
      "type": "linear",
      "direction": "vertical",
      "spacing": 16,
      "children": [
        {
          "type": "text",
          "text": "button variants",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "wrap",
          "spacing": 8,
          "runSpacing": 8,
          "children": [
            {
              "type": "button",
              "label": "Filled",
              "variant": "filled",
              "onTap": {
                "type": "state",
                "action": "increment",
                "binding": "counter"
              }
            },
            {
              "type": "button",
              "label": "Elevated",
              "variant": "elevated",
              "onTap": {
                "type": "state",
                "action": "increment",
                "binding": "counter"
              }
            },
            {
              "type": "button",
              "label": "Outlined",
              "variant": "outlined",
              "onTap": {
                "type": "state",
                "action": "increment",
                "binding": "counter"
              }
            },
            {
              "type": "button",
              "label": "Text",
              "variant": "text",
              "onTap": {
                "type": "state",
                "action": "increment",
                "binding": "counter"
              }
            }
          ]
        },
        {
          "type": "text",
          "text": "Counter: {{counter}}",
          "style": {
            "fontSize": 14
          }
        },
        {
          "type": "text",
          "text": "counter (+/- buttons)",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "linear",
          "direction": "horizontal",
          "spacing": 8,
          "alignment": "center",
          "children": [
            {
              "type": "button",
              "label": " - ",
              "variant": "filled",
              "onTap": {
                "type": "state",
                "action": "decrement",
                "binding": "counter"
              }
            },
            {
              "type": "text",
              "text": "{{counter}}",
              "style": {
                "fontSize": 32,
                "fontWeight": "bold"
              }
            },
            {
              "type": "button",
              "label": " + ",
              "variant": "filled",
              "onTap": {
                "type": "state",
                "action": "increment",
                "binding": "counter"
              }
            },
            {
              "type": "button",
              "label": "Reset",
              "variant": "outlined",
              "onTap": {
                "type": "state",
                "action": "set",
                "binding": "counter",
                "value": 0
              }
            }
          ]
        },
        {
          "type": "text",
          "text": "textInput",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "textInput",
          "label": "Name",
          "placeholder": "Enter your name",
          "binding": "formName"
        },
        {
          "type": "textInput",
          "label": "Email",
          "placeholder": "user@example.com",
          "inputType": "email",
          "binding": "formEmail"
        },
        {
          "type": "text",
          "text": "select (dropdown)",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "select",
          "label": "Choose option",
          "binding": "selectedOption",
          "options": [
            {
              "value": "option1",
              "label": "Option A"
            },
            {
              "value": "option2",
              "label": "Option B"
            },
            {
              "value": "option3",
              "label": "Option C"
            }
          ]
        },
        {
          "type": "text",
          "text": "Selected: {{selectedOption}}",
          "style": {
            "fontSize": 12,
            "color": "#666666"
          }
        },
        {
          "type": "text",
          "text": "toggle",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "toggle",
          "label": "Enable notifications",
          "binding": "toggleValue"
        },
        {
          "type": "text",
          "text": "Toggle: {{toggleValue}}",
          "style": {
            "fontSize": 12,
            "color": "#666666"
          }
        },
        {
          "type": "text",
          "text": "slider",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "slider",
          "min": 0,
          "max": 100,
          "value": "{{sliderValue}}",
          "binding": "sliderValue"
        },
        {
          "type": "text",
          "text": "Value: {{sliderValue}}",
          "style": {
            "fontSize": 12,
            "color": "#666666"
          }
        },
        {
          "type": "text",
          "text": "checkbox",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "checkbox",
          "label": "I agree to the terms",
          "binding": "agreeTerms"
        },
        {
          "type": "text",
          "text": "Agreed: {{agreeTerms}}",
          "style": {
            "fontSize": 12,
            "color": "#666666"
          }
        },
        {
          "type": "text",
          "text": "iconButton",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "linear",
          "direction": "horizontal",
          "spacing": 16,
          "children": [
            {
              "type": "iconButton",
              "icon": "add",
              "size": 28,
              "color": "#2196F3",
              "onTap": {
                "type": "state",
                "action": "increment",
                "binding": "counter"
              }
            },
            {
              "type": "iconButton",
              "icon": "delete",
              "size": 28,
              "color": "#F44336",
              "onTap": {
                "type": "state",
                "action": "set",
                "binding": "counter",
                "value": 0
              }
            },
            {
              "type": "iconButton",
              "icon": "favorite",
              "size": 28,
              "color": "#FF4081",
              "onTap": {
                "type": "state",
                "action": "toggle",
                "binding": "agreeTerms"
              }
            }
          ]
        },
        {
          "type": "text",
          "text": "radio (standalone + via radioGroup)",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "linear",
          "direction": "vertical",
          "children": [
            {
              "type": "radio",
              "value": "a",
              "groupValue": "{{radioChoice}}",
              "label": "Option A",
              "bindTo": "radioChoice",
              "onChange": {
                "type": "state",
                "action": "set",
                "binding": "radioChoice",
                "value": "a"
              }
            },
            {
              "type": "radio",
              "value": "b",
              "groupValue": "{{radioChoice}}",
              "label": "Option B",
              "bindTo": "radioChoice",
              "onChange": {
                "type": "state",
                "action": "set",
                "binding": "radioChoice",
                "value": "b"
              }
            }
          ]
        },
        {
          "type": "text",
          "text": "Radio: {{radioChoice}}",
          "style": {
            "fontSize": 12,
            "color": "#666666"
          }
        },
        {
          "type": "text",
          "text": "rangeSlider",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "rangeSlider",
          "binding": "rangeValue",
          "min": 0,
          "max": 100,
          "divisions": 20
        },
        {
          "type": "text",
          "text": "Range: {{rangeValue.start}} – {{rangeValue.end}}",
          "style": {
            "fontSize": 12,
            "color": "#666666"
          }
        },
        {
          "type": "text",
          "text": "datePicker (button variant)",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "datePicker",
          "label": "Pick a date",
          "binding": "pickedDate",
          "variant": "outlined"
        },
        {
          "type": "text",
          "text": "Date: {{pickedDate}}",
          "style": {
            "fontSize": 12,
            "color": "#666666"
          }
        },
        {
          "type": "text",
          "text": "timePicker (button variant)",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "timePicker",
          "label": "Pick a time",
          "binding": "pickedTime",
          "variant": "outlined"
        },
        {
          "type": "text",
          "text": "Time: {{pickedTime}}",
          "style": {
            "fontSize": 12,
            "color": "#666666"
          }
        },
        {
          "type": "text",
          "text": "dateRangePicker",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "dateRangePicker",
          "label": "Pick a range",
          "startDate": "rangeStart",
          "endDate": "rangeEnd",
          "firstDate": "2026-01-01",
          "lastDate": "2026-12-31"
        },
        {
          "type": "text",
          "text": "Range: {{rangeStart}} → {{rangeEnd}}",
          "style": {
            "fontSize": 12,
            "color": "#666666"
          }
        },
        {
          "type": "text",
          "text": "colorPicker",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "colorPicker",
          "binding": "pickedColor",
          "showLabel": true,
          "pickerType": "palette"
        },
        {
          "type": "text",
          "text": "Color: {{pickedColor}}",
          "style": {
            "fontSize": 12,
            "color": "#666666"
          }
        },
        {
          "type": "text",
          "text": "stepper (wizard)",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "stepper",
          "binding": "stepperIndex",
          "steps": [
            {
              "titleText": "Account",
              "content": {
                "type": "text",
                "text": "Create an account"
              }
            },
            {
              "titleText": "Profile",
              "content": {
                "type": "text",
                "text": "Complete your profile"
              }
            },
            {
              "titleText": "Review",
              "content": {
                "type": "text",
                "text": "Review your info"
              }
            }
          ]
        },
        {
          "type": "text",
          "text": "numberStepper (+/-)",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "numberStepper",
          "label": "Quantity",
          "binding": "numberStepperValue",
          "min": 0,
          "max": 20,
          "step": 1
        },
        {
          "type": "text",
          "text": "Count: {{numberStepperValue}}",
          "style": {
            "fontSize": 12,
            "color": "#666666"
          }
        },
        {
          "type": "text",
          "text": "rating",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "rating",
          "binding": "ratingValue",
          "max": 5,
          "icon": "star",
          "color": "#FFC107"
        },
        {
          "type": "text",
          "text": "Rating: {{ratingValue}}",
          "style": {
            "fontSize": 12,
            "color": "#666666"
          }
        },
        {
          "type": "text",
          "text": "form submit",
          "style": {
            "fontSize": 16,
            "fontWeight": "bold",
            "color": "#2196F3"
          }
        },
        {
          "type": "button",
          "label": "Submit form",
          "variant": "filled",
          "onTap": {
            "type": "tool",
            "tool": "submitForm",
            "params": {
              "name": "{{formName}}",
              "email": "{{formEmail}}"
            },
            "onSuccess": {
              "type": "state",
              "action": "set",
              "binding": "formResult",
              "value": "{{response.formResult}}"
            }
          }
        },
        {
          "type": "text",
          "text": "{{formResult}}",
          "style": {
            "fontSize": 14,
            "color": "#4CAF50"
          }
        },
        {
          "type": "sizedBox",
          "height": 24
        }
      ]
    }
  }
}